SONAR_API_HOST=127.0.0.1
SONAR_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3111,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3111,http://tauri.localhost,tauri://localhost
# Optional. When set, all mutating requests must include: X-Sonar-Token: <value>
SONAR_API_TOKEN=

# Desktop users configure generation in the UI. These env vars are for API mode.
SONAR_CHAT_BASE_URL=http://localhost:8080/v1
SONAR_CHAT_MODEL=Qwen/Qwen3.5-9B
SONAR_CHAT_API_KEY=not-needed

# Desktop mode starts Dockerized Ollama for embeddings.
SONAR_EMBEDDING_PROVIDER=ollama
SONAR_OLLAMA_BASE_URL=http://localhost:11434
SONAR_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

SONAR_MEILI_HOST=http://localhost:7700
SONAR_MEILI_API_KEY=masterKey
SONAR_QDRANT_HOST=localhost
SONAR_QDRANT_PORT=6333
SONAR_QDRANT_VECTOR_SIZE=768

SONAR_DATA_DIR=$HOME/.sonar
SONAR_DB_PATH=$HOME/.sonar/projects.db
SONAR_MAX_CONTEXT_TOKENS=5000
SONAR_MAX_RESPONSE_TOKENS=2000
SONAR_TEMPERATURE=0.1

# By default Sonar only indexes repositories under the process working directory.
# Set this to one or more explicit roots for normal use.
SONAR_ALLOWED_REPO_ROOTS=/Users/you/code,/Users/you/work
# Development escape hatch. Do not enable for a browser-accessible server.
SONAR_ALLOW_ANY_REPO_ROOT=false
