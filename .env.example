# Optional API-mode endpoint overrides.
# Desktop users normally configure these from the app UI.

# OpenAI-compatible generation API, for example llama-server, vLLM, OpenAI, or another hosted endpoint.
SONAR_CHAT_BASE_URL=http://localhost:8080/v1
SONAR_CHAT_MODEL=local-chat-model
SONAR_CHAT_API_KEY=not-needed

# Local briefing generation can be slow; default is 180000 ms (3 minutes).
# Desktop model settings flow into these same runtime values.
SONAR_CHAT_TIMEOUT_MS=180000

# Retries are explicit transport retries only. Timeout, auth, and rate-limit failures are not retried.
# Set to 0 for no transport retries; default is 1 and values are capped at 4.
SONAR_CHAT_MAX_RETRIES=1

# By default, local OpenAI-compatible endpoints disable model reasoning/thinking when supported.
# Set false if your local model/server requires reasoning to remain enabled.
SONAR_DISABLE_MODEL_REASONING=
