# Optional API-mode endpoint overrides.
# Desktop users configure generation from the app UI.

# OpenAI-compatible generation API, for example llama-server, vLLM, or OpenAI.
SONAR_CHAT_BASE_URL=http://localhost:8080/v1

# OpenAI-compatible embeddings API. Docker Model Runner also exposes this shape.
SONAR_EMBEDDING_BASE_URL=http://localhost:12434/engines/v1

# Local support services. Desktop mode manages these through Docker by default.
SONAR_MEILI_HOST=http://localhost:7700
SONAR_QDRANT_HOST=localhost
SONAR_QDRANT_PORT=6333
SONAR_OLLAMA_BASE_URL=http://localhost:11434
