# Optional API-mode endpoint overrides.
# Desktop users normally configure these from the app UI.

# OpenAI-compatible generation API, for example Docker Model Runner, llama-server, vLLM, or OpenAI.
SONAR_CHAT_BASE_URL=http://localhost:8080/v1
SONAR_CHAT_MODEL=local-chat-model
SONAR_CHAT_API_KEY=not-needed

# Local search service. Desktop mode manages this through Docker by default.
SONAR_MEILI_HOST=http://localhost:7700
