{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "*.json",
      "*.ts",
      "src/**/*.ts",
      "test/**/*.ts",
      "src-ui/**/*.css",
      "src-ui/**/*.html",
      "src-ui/**/*.ts",
      "src-ui/**/*.tsx",
      "!dist",
      "!dist-ui",
      "!node_modules",
      "!src-tauri/gen",
      "!src-tauri/target"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off",
        "useNodejsImportProtocol": "off",
        "useTemplate": "off"
      }
    }
  }
}
