{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonar",
  "version": "0.1.0",
  "identifier": "com.sonar.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist-ui"
  },
  "app": {
    "windows": [
      {
        "title": "Sonar",
        "width": 1360,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png"
    ]
  }
}
