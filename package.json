{
  "name": "sonar",
  "version": "0.1.0",
  "description": "Local-first codebase onboarding and explanation engine",
  "main": "dist/index.js",
  "files": [
    "dist",
    "grammars",
    "README.md",
    "package.json",
    "package-lock.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:dev",
    "test:dev": "node --test -r ts-node/register test/*.test.ts",
    "test:integration": "node --test -r ts-node/register test/*.integration.ts || (echo 'No integration tests found or integration tests failed' && exit 1)",
    "check": "npm run typecheck && npm run test:dev",
    "eval:retrieval": "ts-node src/eval/retrieval-cli.ts",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "better-sqlite3": "^12.8.0",
    "express": "^4.22.1",
    "meilisearch": "^0.41.0",
    "openai": "^6.32.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cli": "^0.26.7",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
