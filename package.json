{
  "name": "sonar",
  "version": "0.1.0",
  "description": "Understand any codebase. Ask what matters.",
  "license": "MIT",
  "main": "dist/index.js",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10"
  },
  "files": [
    "dist",
    "grammars",
    "README.md",
    "package.json",
    "package-lock.json"
  ],
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build",
    "dev:ui": "vite --host 127.0.0.1",
    "format": "biome format --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:check": "biome format . && cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "lint": "biome lint . && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc --noEmit -p tsconfig.ui.json",
    "test": "npm run test:dev",
    "test:dev": "node --test -r ts-node/register test/*.test.ts",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:ui && npm run test:dev",
    "eval:retrieval": "ts-node src/eval/retrieval-cli.ts",
    "services:env": "node scripts/ensure-runtime-env.mjs",
    "services:wait": "node scripts/wait-for-services.mjs",
    "services:start": "npm run services:env && docker compose up -d --build && npm run services:wait",
    "services:stop": "docker compose down --remove-orphans",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "desktop:dev": "tauri dev",
    "desktop:build": "npm run build && npm run build:ui && tauri build --bundles app",
    "desktop:bundle": "npm run build && npm run build:ui && tauri build"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "better-sqlite3": "^12.8.0",
    "express": "^4.22.1",
    "meilisearch": "^0.41.0",
    "openai": "^6.32.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cli": "^0.26.7",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.14"
  }
}
